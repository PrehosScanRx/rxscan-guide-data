{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.rxscan.ca/guide-data/guide-release-manifest-1.0.0.schema.json",
  "title": "RxScan Guide editorial release manifest",
  "type": "object",
  "additionalProperties": false,
  "dependentRequired": {
    "capabilities": ["linkage"],
    "linkage": ["capabilities"]
  },
  "required": ["schemaVersion", "releaseId", "contentVersion", "generatedAt", "sourceCommit", "publicationSource", "releaseStatus", "compatibility", "minimumGuideVersion", "files", "counts", "provenance"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "releaseId": { "type": "string", "pattern": "^guide-catalog-[a-z0-9][a-z0-9._-]+\\+[a-f0-9]{12}$" },
    "contentVersion": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "publicationSource": { "enum": ["canonical", "controlled-import", "fixture"] },
    "releaseStatus": { "const": "candidate" },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifestSchema", "catalogSchema", "offlineCapable"],
      "properties": {
        "manifestSchema": { "const": "1.x" },
        "catalogSchema": { "const": "1.x" },
        "offlineCapable": { "const": true }
      }
    },
    "minimumGuideVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rxIdLinkedGuideCards"],
      "properties": { "rxIdLinkedGuideCards": { "const": true } }
    },
    "linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["totalGuideCardCount", "activeGuideCardCount", "linkedRxIdCount", "unlinkedGuideCardCount", "guideSourceCommit", "medicationDirectory", "catalogSha256"],
      "properties": {
        "totalGuideCardCount": { "type": "integer", "minimum": 0 },
        "activeGuideCardCount": { "type": "integer", "minimum": 0 },
        "linkedRxIdCount": { "type": "integer", "minimum": 0 },
        "unlinkedGuideCardCount": { "const": 0 },
        "guideSourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "catalogSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "medicationDirectory": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sourceRepository", "sourceCommit", "releaseId", "directorySha256"],
          "properties": {
            "sourceRepository": { "type": "string", "minLength": 1 },
            "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
            "releaseId": { "type": ["string", "null"], "minLength": 1 },
            "directorySha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        }
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role", "mediaType", "bytes", "sha256", "recordCount", "required"],
        "properties": {
          "path": { "type": "string", "pattern": "^(?![A-Za-z]:)(?![/\\\\])(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9@._/-]+$" },
          "role": { "enum": ["guide-catalog"] },
          "mediaType": { "const": "application/json" },
          "bytes": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "recordCount": { "type": "integer", "minimum": 0 },
          "required": { "const": true }
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["totalCount", "approvedCount", "reviewCount", "draftCount", "disabledCount"],
      "properties": {
        "totalCount": { "type": "integer", "minimum": 0 },
        "approvedCount": { "type": "integer", "minimum": 0 },
        "reviewCount": { "type": "integer", "minimum": 0 },
        "draftCount": { "type": "integer", "minimum": 0 },
        "disabledCount": { "type": "integer", "minimum": 0 }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceRepository", "sourceCommit", "importedAt", "clinicalSource", "clinicalSourceVersion"],
      "properties": {
        "sourceRepository": { "type": "string", "minLength": 1 },
        "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "importedAt": { "type": "string", "format": "date-time" },
        "clinicalSource": { "type": ["string", "null"] },
        "clinicalSourceVersion": { "type": ["string", "null"] }
      }
    }
  }
}
